# Database
DATABASE_URL=postgresql://portfolio_user:password@localhost:5432/portfolio_db
DIRECT_URL=postgresql://portfolio_user:password@localhost:5432/portfolio_db

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Supabase Storage
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...
MAX_FILE_SIZE=5242880

# Email (Contact Form)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ansellino@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Portfolio <noreply@domain.com>
ADMIN_NOTIFY_EMAIL=ansellino@gmail.com

# Seed
ADMIN_EMAIL=ansellino@gmail.com
ADMIN_PASSWORD=your-admin-password

# Docker Compose (local dev)
POSTGRES_USER=portfolio_user
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=portfolio_db

PORT=3000
